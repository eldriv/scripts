#!/usr/bin/env bash
# WordPress Docker launcher — macOS, Windows (Git Bash/WSL), and Linux (2026)

set -eu
set -o pipefail

readonly SELF="${BASH_SOURCE[0]}"
readonly BASE_SELF=$(basename "$SELF")
readonly WORDPRESS_DIR="${PWD}/docker-wordpress"

# Detect OS for cross-platform behavior (macOS, Windows Git Bash/MSYS, Linux)
detect_os() {
  case "$(uname -s 2>/dev/null)" in
    Darwin)   echo "macos" ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *)        echo "linux" ;;
  esac
}
readonly PLATFORM=$(detect_os)

OPT_HELP=
OPT_DEBUG=
OPT_VERBOSE=
OPT_RUN=
OPT_STOP=

error () { echo "Error: $@" >&2; exit 1; }

display_usage () {
  cat <<EOF
Usage: $BASE_SELF [OPTIONS]

Options:
-h, --help       Display this help message.
-d, --debug      Enable debug mode.
-v, --verbose    Enable verbose output.
-r, --run        Run the WordPress Docker Compose.
-s, --stop       Stop the Wordpress Docker Services.
To run and kill the WordPress, here is the command:
$BASE_SELF -r, --run
$BASE_SELF -s, --stop
EOF
  exit 0
}

debug() {
  if [[ -n "$OPT_DEBUG" ]]; then
    echo "[DEBUG] $@"
  fi
}

run_wordpress() {
  debug "Starting WordPress services..."

  # Navigate the Docker Compose directory
  cd "$WORDPRESS_DIR" || { echo "Directory not found!"; return 1; }

  # Start the Docker Compose services
  if ! docker compose up -d; then
    error "Failed to execute Docker Compose."
  fi

  # Open the default web browser (macOS, Windows Git Bash, Linux)
  open_browser "http://localhost:8080/"
}

open_browser() {
  local url="${1:-http://localhost:8080/}"
  case "$PLATFORM" in
    macos)
      if command -v open &>/dev/null; then
        echo "Successfully opened $url in your web browser."
        open "$url"
      else
        echo "Could not open browser. Visit $url manually."
      fi
      ;;
    windows)
      if command -v cmd.exe &>/dev/null; then
        echo "Successfully opened $url in your web browser."
        cmd.exe //c start "" "$url"
      elif command -v start &>/dev/null; then
        echo "Successfully opened $url in your web browser."
        start "$url"
      else
        echo "Could not open browser. Visit $url manually."
      fi
      ;;
    linux)
      if command -v xdg-open &>/dev/null; then
        echo "Successfully opened $url in your web browser."
        xdg-open "$url"
      elif command -v firefox &>/dev/null; then
        echo "Successfully opened $url in Firefox."
        firefox "$url"
      else
        echo "Could not open browser. Visit $url manually."
      fi
      ;;
    *)
      echo "Visit $url in your browser."
      ;;
  esac
}

stop_wordpress() {
  # Navigate the Docker Compose directory
  cd "$WORDPRESS_DIR" || { echo "Directory not found!"; return 1; }

  if [ "$(docker ps -q)" ]; then
    # If T it automatically stop and remove containers.
    if docker compose down; then
      echo "WordPress successfully closed!"
    else
      error "WordPress cannot be closed!"
    fi
  else
    echo "There are no services to close."
  fi

}

parse_arguments() {
  local valid_commands=(
    -h --help
    -d --debug
    -v --verbose
    -r --run
    -s --stop
  )
  for arg in "$@"; do
    if [[ " ${valid_commands[*]} " =~ " $arg " ]]; then
      case "$arg" in
        -h|--help) OPT_HELP=1 ;;
        -d|--debug) OPT_DEBUG=1 ;;
        -v|--verbose) OPT_VERBOSE=1 ;;
        -r|--run) OPT_RUN=1 ;;
        -s|--stop) OPT_STOP=1 ;;
      esac
    else
      error "Invalid command '$arg'. Please see '$BASE_SELF --help.'"
    fi
  done
}

process_options () {
  [[ -n "$OPT_HELP" ]] && display_usage
  [[ -n "$OPT_RUN" ]] && run_wordpress
  [[ -n "$OPT_STOP" ]] && stop_wordpress
  [[ -n "$OPT_VERBOSE" ]] && echo "starting Docker Compose in $WORDPRESS_DIR"
}

main () {
  parse_arguments "$@"
  process_options
}

main "$@"
